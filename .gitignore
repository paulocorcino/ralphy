# Rust build artifacts (workspace target dir).
/target/

# Release packaging staging dir (produced by the Release workflow).
/dist/

# Ralphy writes run logs/scratch into the TARGET repo's .ralphy/, not here.
# These patterns are only a safety net for stray local runtime artifacts.
runs/
worktrees/
state/
# Ralphy run artifacts (scratch, logs, per-run plans)
.ralphy/
